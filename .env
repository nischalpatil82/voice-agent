# Local development overrides for JustBill voice agent
# SECURITY NOTE: Keep TLS verification enabled in production.
VOICE_AGENT_PRODUCTION=false
JUSTBILL_VERIFY_TLS=false
JUSTBILL_FETCH_LIVE_EVERY_REQUEST=true
JUSTBILL_RELOAD_EVERY=0
VOICE_AGENT_CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://192.168.2.16:4200,http://localhost:4300,http://127.0.0.1:4300,http://192.168.2.16:4300
