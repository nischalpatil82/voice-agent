# -----------------------------
# Voice Agent core settings
# -----------------------------
VOICE_AGENT_LOG_LEVEL=INFO
VOICE_AGENT_PRODUCTION=false
VOICE_AGENT_CORS_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
VOICE_AGENT_ALLOW_LOCALHOST_ORIGINS=false
VOICE_AGENT_TRUST_PROXY_HEADERS=false
VOICE_AGENT_REQUIRE_ADMIN_TOKEN=false
VOICE_AGENT_ADMIN_TOKEN=
VOICE_AGENT_REQUIRE_PUBLIC_TOKEN=false
VOICE_AGENT_PUBLIC_TOKEN=
VOICE_AGENT_ENABLE_ANALYTICS=false
VOICE_AGENT_ACCESS_LOG=true
VOICE_AGENT_RATE_LIMIT_MAX=60
VOICE_AGENT_RATE_LIMIT_WINDOW_SECONDS=60
VOICE_AGENT_SESSION_TTL_SECONDS=1800
VOICE_AGENT_SESSION_CLEANUP_SECONDS=300
VOICE_AGENT_MAX_TEXT_LENGTH=500
VOICE_AGENT_MAX_CONTENT_LENGTH_BYTES=10485760
VOICE_AGENT_MAX_QUANTITY=50
VOICE_AGENT_PRELOAD_WHISPER=true
VOICE_AGENT_WORKER_THREADS=8
VOICE_AGENT_FAIL_STARTUP_ON_CATALOG_DEGRADED=false
VOICE_AGENT_OUTBOUND_TIMEOUT=2.0
VOICE_AGENT_OUTBOUND_WORKERS=4
VOICE_AGENT_LOG_PREDICTIONS=false
VOICE_AGENT_SPEAK=true
VOICE_AGENT_TTS_RATE=175
VOICE_AGENT_TTS_VOLUME=1.0
VOICE_AGENT_TTS_VOICE_HINT=
VOICE_AGENT_PAUSE_THRESHOLD=0.55
VOICE_WHISPER_MODEL=small
VOICE_WHISPER_COMPUTE=int8
VOICE_WHISPER_DEVICE=cpu

# -----------------------------
# JustBill API security
# -----------------------------
JUSTBILL_VERIFY_TLS=true
JUSTBILL_API_TIMEOUT_SECONDS=15
JUSTBILL_CA_BUNDLE_PATH=
JUSTBILL_ACTION_API_URL=
JUSTBILL_RELOAD_EVERY=300
JUSTBILL_FETCH_LIVE_EVERY_REQUEST=false
JUSTBILL_FAILURE_THRESHOLD=3
JUSTBILL_CIRCUIT_OPEN_SECONDS=45
JUSTBILL_STRICT_CATALOG=false
JUSTBILL_MAX_DEGRADED_SECONDS=900
JUSTBILL_ALLOW_FALLBACK_IN_PRODUCTION=false
JUSTBILL_VOICE_HINT_USE_FULL_CATALOG=true
JUSTBILL_VOICE_CONTEXT_PRODUCT_LIMIT=12
JUSTBILL_VOICE_CONTEXT_TERM_LIMIT=48

